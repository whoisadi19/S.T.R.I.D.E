<?xml version="1.0"?>
<model>
  <name>simple_drone</name>
  <version>2.0</version>
  <sdf version="1.6">model.sdf</sdf>
  <author>
    <name>S.T.R.I.D.E Team</name>
    <email>whoisadi19@github.com</email>
  </author>
  <description>
    A detailed quadcopter drone model with 4 arms, motors, propellers,
    landing gear, camera gimbal, and LiDAR for autonomous infrastructure
    inspection. Built entirely from SDF primitives (no external meshes).
    Movement is kinematic, controlled by kinematics_node via /set_entity_state.
  </description>
</model>
